rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token &&
             request.auth.token.email == 'mathunion33@gmail.com' && 
             'email_verified' in request.auth.token &&
             request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isBootstrapAdmin() || (isSignedIn() && getUserData() != null && getUserData().role == 'admin');
    }

    // User Profile Validation
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['user', 'admin'];
    }

    // Order Validation
    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.items is list &&
             data.total is number &&
             data.status in ['received', 'buying', 'preparing', 'on_the_way', 'delivered'];
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId) && isValidUserProfile(incoming());
      allow update: if (isSignedIn() && (request.auth.uid == userId || isAdmin())) && (
        isAdmin() || (incoming().role == existing().role)
      );
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
